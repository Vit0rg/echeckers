#! /usr/bin/env bash
# Multi-step build system for echeckers
# Builds main game and battle module separately

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"  # Go to project root
cd "$PROJECT_ROOT"

# Build configuration
declare -A BUILDS=(
    ["main"]="build_systems/build_main.txt processed_script.lua"
    ["battle"]="build_systems/build_battle.txt battle/processed_battle.lua"
)

build_failed=0

build_step() {
    local name="$1"
    local config_file="$2"
    local target="$3"

    echo "========================================"
    echo "BUILD STEP: $name"
    echo "Config: $config_file -> Output: $target"
    echo "========================================"

    if [[ ! -f "$config_file" ]]; then
        echo "ERROR: Config file not found: $config_file"
        return 1
    fi

    local files_to_process=()

    while IFS= read -r entry || [[ -n "$entry" ]]; do
        [[ -z "$entry" || "$entry" =~ ^# ]] && continue

        local full_path="$PROJECT_ROOT/$entry"
        
        if [[ -d "$full_path" ]]; then
            while IFS= read -r file; do
                files_to_process+=("$file")
            done < <(find "$full_path" -type f -name "*.lua")
        elif [[ -f "$full_path" ]]; then
            files_to_process+=("$full_path")
        else
            echo "WARNING: File not found: $full_path"
        fi
    done < "$config_file"
    
    echo ""
    echo "Files to concatenate (${#files_to_process[@]}):"
    for item in "${files_to_process[@]}"; do
        echo "  $item"
    done
    echo ""
    
    # Build the output
    echo "" > "$target"
    for file in "${files_to_process[@]}"; do
        echo "-- $file" >> "$target"
        cat "$file" >> "$target"
        echo "" >> "$target"
    done
    
    echo "Output: $target ($(wc -l < "$target") lines)"
    echo ""
    return 0
}

# Run build steps
for name in "${!BUILDS[@]}"; do
    read -r config target <<< "${BUILDS[$name]}"
    if ! build_step "$name" "$config" "$target"; then
        build_failed=1
    fi
done

echo "========================================"
if [[ $build_failed -eq 0 ]]; then
    echo "BUILD COMPLETE: All steps succeeded"
else
    echo "BUILD FAILED: One or more steps failed"
fi
echo "========================================"

exit $build_failed
